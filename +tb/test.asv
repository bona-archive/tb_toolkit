% graphene
basis = [sqrt(3)/3,0;
    2*sqrt(3)/3, 0];

a1 = [sqrt(3)/2, 1/2];
a2 = [sqrt(3)/2, -1/2];
latvecs = [a1;a2];

onsite = [0;0];

neighbor_order = [1];
t_vals = [1];

% triangle
a1 = [1, 0];
a2 = [1/2, sqrt(3)/2];
[0, 0];              % Site A (Sublattice 1)
b(2, :) = [1/2, sqrt(3)/6];    % Site B (Sublattice 2)
b(3, :) = [0, sqrt(3)/3];      % Site C (Sublattice 3)


latvecs = [a1;a2];
hops = tb.make_hops(basis, latvecs, neighbor_order, t_vals, doPlot=true);

kpts = {[0,0],[2*pi/sqrt(3), 2*pi/3],[pi/sqrt(3),pi],[0,0]};
labels = {'\Gamma','K','M','\Gamma'};
N_pts = 100;
[k_path, k_dist, ticks, labels] = tb.kpath(kpts,labels, N_pts);

band = zeros(size(basis,1),size(k_path,1));
for k_ind = 1:size(k_path,1)
    k_vec = k_path(k_ind,:);
    Hk = tb.blochham(k_vec, basis, latvecs, hops, onsite);
    [u,d] = eig((Hk+Hk')/2);
    band(:,k_ind) = sort(diag(d));
end

figure
hold on
for band_ind = 1:size(band,1)
    plot(k_dist,band(band_ind,:));

end
set(gca, 'XTick', ticks, 'XTickLabel', labels, 'FontSize', 30);
